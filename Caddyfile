{
  email {$CADDY_EMAIL}
  admin 0.0.0.0:2019

  # On-demand TLS: Caddy asks DomainProxy before issuing any certificate
  on_demand_tls {
    ask http://proxy:3000/api/v1/verify-domain
  }
}

# DomainProxy admin UI — replace with your domain
yourdomain.com {
  reverse_proxy proxy:3000 {
    header_up Host {host}
  }
}

# Catch-all: any registered customer domain gets automatic HTTPS
https:// {
  tls {
    on_demand
  }
  reverse_proxy proxy:3000 {
    header_up Host {host}
  }
}

# HTTP catch-all (handles ACME challenges and HTTP traffic)
http:// {
  reverse_proxy proxy:3000 {
    header_up Host {host}
  }
}
